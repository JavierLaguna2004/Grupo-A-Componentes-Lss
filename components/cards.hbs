<section class="cards-section">
    <div class="row gap-4">
        {{#each cards}}
            <div class="col-4 col-md-3">
                <div class="card rounded shadow">
                    <div class="card-icon">{{card-icon}}</div>
                    <h3>{{card-title}}</h3>
                    <p>{{card-text}}</p>
                </div>
            </div>
        {{/each}}
    </div>
</section>